# Copy to .env.local and fill in from your Supabase project settings.
# .env.local is git-ignored — never commit real values.

# --- Public (client-safe). Set these in Vercel AND locally. ---
# Sent to the browser; safe to expose. Used by the web app's Supabase SSR clients.
NEXT_PUBLIC_SUPABASE_URL=https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=<anon-public-key>

# --- Server-only. Set these ONLY in your local .env.local, NEVER in Vercel. ---
# Used exclusively by the local pipeline (scripts/pipeline.ts) + db tests to write
# priced quotes via the service-role client (bypasses RLS). The Vercel web app
# never reads these. Shipping the service-role key to the browser = full god-key leak.
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service-role-secret-key>
